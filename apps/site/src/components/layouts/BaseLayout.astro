---
import "@maxhill/css";

interface Props {
    title: string;
    bodyClass?: string;
}

const { title, bodyClass } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <title>maxhill.me - {title}</title>
        
        <!-- SEO Meta Tags -->
        <meta name="description" content="Max Hill" />
        <meta name="author" content="Max Hill" />
        
        <!-- OpenGraph Tags -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content={`maxhill.me - ${title}`} />
        <meta property="og:description" content="Max hill" />
        <meta property="og:url" content="https://maxhill.me" />
        <meta property="og:site_name" content="maxhill.me" />
        
        <!-- Twitter Card Tags -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={`maxhill.me - ${title}`} />
        <meta name="twitter:description" content="Max Hill" />

        <link
            rel="preload"
            href="/fonts/optimized/IBMPlexMono-Regular.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/optimized/IBMPlexMono-Medium.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/optimized/IBMPlexMono-Bold.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/optimized/DepartureMono-Regular.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />

        <script>
            (function () {
                const theme = localStorage.getItem("theme");
                if (theme) {
                    document.documentElement.setAttribute("data-theme", theme);
                } else if (
                    window.matchMedia("(prefers-color-scheme: dark)").matches
                ) {
                    document.documentElement.setAttribute("data-theme", "dark");
                } else {
                    document.documentElement.setAttribute(
                        "data-theme",
                        "light",
                    );
                }
            })();
        </script>
    </head>
    <body class={bodyClass}>
        <slot />
        
        <script>
            import "@maxhill/components/register-all";
        </script>
    </body>
</html>
