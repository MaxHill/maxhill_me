---
import BaseLayout from "../components/layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  <main class="exposed-grid background-pattern" data-pattern="diagonal">
    <a href="/" class="home"><span>maxhill.me</span></a>
    <a href="/design-system" class="design-system" title="Design tokens, patterns, and systematic guidelines"><span>Design System</span></a>
    <a href="/components" class="components" title="Web component library and documentation"><span>Components</span></a>
    <m-fit-text font-display>Max <br/> Hill</m-fit-text>
  </main>
</BaseLayout>

<style>
  main {
    height: 100dvh;
    width: 100dvw;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: 1fr;
    border-block: var(--border);
    direction: rtl;

    @media (width > 900px) { direction: ltr; }
  }

  a {
    writing-mode: vertical-rl;
    background-color: var(--color-background);
    text-decoration: none;
    position: relative;
    isolation: isolate;
    font-family: var(--ff-display);
    overflow:hidden;

    font: var(--h2);

    /* Pattern variables for hover effect */
    --_color-fg: var(--color-primary-stroke-soft);
    --_color-bg: transparent;
    --_size: 10px 10px;
    --_pattern-opacity: 0;

    /* Instant background color change, fade in pattern */
    transition: --_pattern-opacity 0.4s ease-out;

    &::before {
      content: '';
      position: absolute;
      inset: 0;
      background-size: var(--_size);
      opacity: var(--_pattern-opacity);
      transition: opacity 0.4s ease-out;
      pointer-events: none;
      z-index: -1;
    }

    & > span {
      background: var(--color-background);
      position: relative;
      padding: 0;
      
      @media (width > 768px) {
        right: var(--body-margin);
        padding: var(--body-margin);
      }
    }

    &:hover {
      text-decoration: underline;
      background-color: var(--color-primary-fill-softer);
      --_pattern-opacity: 1;

      & > span {
        background: var(--color-primary-fill-softer);
      }
    }

    &:focus-visible {
      outline: var(--outline);
      outline-offset: calc(-1 * var(--outline-size));
      background-color: var(--color-primary-fill-softer);
      --_pattern-opacity: 1;

      & > span {
        background: var(--color-primary-fill-softer);
      }
    }
  }

  .home {
    grid-column: span 1;

    &::before {
      background-image: radial-gradient(var(--_color-fg) 1px, var(--_color-bg) 1px);
    }
  }

  .design-system {
    grid-column: span 2;

    &::before {
      background-image: repeating-linear-gradient(to right,
        var(--_color-fg),
        var(--_color-fg) 1px,
        var(--_color-bg) 1px,
        var(--_color-bg));
    }
  }

  .components {
    grid-column: span 3;

    &::before {
      background-image: 
        linear-gradient(var(--_color-fg) 1px, transparent 1px),
        linear-gradient(to right, var(--_color-fg) 1px, var(--_color-bg) 1px);
    }
  }

  m-fit-text {
    grid-column: 8 / span 5;
    background: var(--color-background);
    text-align: right;
  }

  /* Respect reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    * {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
