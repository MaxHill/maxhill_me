---
import PageLayout from "../../components/layouts/PageLayout.astro";
import { getCollection } from "astro:content";
import { getComponentByTagName } from "@wc-toolkit/cem-utilities";
import customElements from "@maxhill/components/custom-elements.json";

const title = "Components";

const docEntries = await getCollection("componentDocs");

// Helper function to check if a component is form-associated
function isFormAssociated(component: any): boolean {
  return component?.members?.some(
    (m: any) => m.name === "formAssociated" && 
                m.static === true && 
                m.default === "true"
  ) ?? false;
}

// Helper function to extract first line or sentence from description
function formatDescription(description: string | undefined): string {
  if (!description) return "";
  
  // Split by newline and get first non-empty line
  const firstLine = description.split("\n")[0].trim();
  
  // If it's a complete sentence (ends with period), return it
  if (firstLine.endsWith(".")) {
    return firstLine;
  }
  
  // Otherwise, find first sentence
  const firstSentence = description.match(/^[^.!?]+[.!?]/);
  if (firstSentence) {
    return firstSentence[0].trim();
  }
  
  // Fall back to first line
  return firstLine;
}

const components = docEntries
  .map((docsEntry) => {
    const tagName = docsEntry.id.split("/").slice(-2, -1)[0];

    if (!tagName) {
      return null;
    }

    // Get component metadata from custom elements manifest
    const manifestComponent = getComponentByTagName(customElements, tagName);
    
    return {
      tagName,
      componentPath: tagName.substring(2),
      description: formatDescription(manifestComponent?.description),
      formAssociated: isFormAssociated(manifestComponent),
    };
  })
  .filter(Boolean);
---

<PageLayout title={title} bodyClass="component-index-page">
  <main>
    <m-fit-text class="title" font-display>
      <h1 data-margin="0">Search Components</h1>
    </m-fit-text>

    <m-search-list target="#component-selector">
      <m-input placeholder="Filter components.."></m-input>
      <m-listbox
        id="component-selector"
        class="grid exposed-grid"
        mode="single-focus"
        skip="[data-match='false']"
      >
        <div class="title-row component-row exposed-grid">
          <div class="name">Name</div>
          <div class="tag">Tag</div>
          <div class="description">Description</div>
          <div class="form-associated">Form</div>
        </div>
        {
          components.map((component) => (
            <m-option
              value={component?.componentPath}
              class="component-row exposed-grid"
              data-keywords={component?.tagName}
              data-subgrid
            >
              <div class="name">{component?.tagName}</div>
              <div class="tag">&lt;{component?.tagName}&gt;</div>
              <div class="description">
                {component?.description || "No description available"}
              </div>
              <div class="form-associated">{component?.formAssociated ? "Yes" : "No"}</div>
            </m-option>
          ))
        }
      </m-listbox>
    </m-search-list>
  </main>

  <script>
    import type { MListbox } from "@maxhill/components/m-listbox/index";

    const list_box = document.getElementById(
      "component-selector",
    ) as MListbox;
    list_box?.addEventListener("m-listbox-change", () => {
      window.location.href = `/components/${list_box.value}`;
    });
  </script>

  <style>
    :global(.component-index-page) {
      padding-top: var(--menu-height);
      display: grid;

      main {
        width: 100%;
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: auto auto;
        align-content: start;
        --outline-offset: calc(var(--outline-size) * -1);
      }
    }

    m-search-list {
      display: grid;
      gap: 0;
      padding: 0;
      margin: var(--body-margin) auto;
      grid-template-rows: auto auto;
      grid-template-columns: 1fr;
      align-content: start;
      width: 100%;
      max-width: 1000px;
    }
    .grid {
      gap: 0;
      padding: 0;
      grid-auto-rows: auto;
    }
    .search-row {
      gap: 0;
      padding: 0;
    }
    .component-row {
      gap: 0;
      padding: 0;
      display: grid;
      grid-template-columns: 20% 20% 45% 15%;

      @media (width < 700px) {
        grid-template-columns: 40% 40% 20%;
        .description {
          display: none;
        }
      }

      &.title-row {
        font-weight: var(--font-weight-bold);
        background: var(--color-surface);
      }

      div {
        padding: var(--size-1);
      }
    }

    .title {
      margin-top: var(--size-fluid-3);
    }

    m-option[data-match="false"] {
      display: none;
    }
  </style>
</PageLayout>
